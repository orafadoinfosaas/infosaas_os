---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTASection from "../../components/CTASection.astro";

const inclusos = [
  { titulo: "Atendimento prioritário", desc: "A mesma equipe que conhece o projeto. Sem fila genérica, sem explicar o contexto do zero para um atendente que nunca viu o código." },
  { titulo: "Relatórios de performance", desc: "Transparência sobre o que foi feito, quanto tempo levou e qual o impacto. Nenhuma hora desaparece sem registro." },
  { titulo: "Ajustes de design sob demanda", desc: "Melhorias de interface, identidade visual ou UX dentro da franquia mensal — sem contratar um designer separado." },
  { titulo: "Evolução de código", desc: "Novas funcionalidades, integrações, otimizações de performance ou refatorações dentro do volume mensal contratado." },
  { titulo: "Registro detalhado de atividades", desc: "Documentação de tudo que foi alterado, com contexto. O produto não fica na cabeça de uma pessoa — fica registrado." },
];

const perfis = [
  { titulo: "Produto lançado, equipe desmobilizada", desc: "O projeto foi entregue, o time foi liberado. Agora surgem ajustes, melhorias e bugs — sem ninguém para responder com agilidade e conhecimento do projeto." },
  { titulo: "Evolução constante no roadmap", desc: "O produto existe, funciona, mas o mercado pede novas features. Contratar um time fixo para uma demanda variável não faz sentido econômico." },
  { titulo: "Operação que não pode parar", desc: "O sistema é crítico para o negócio. Uma falha não resolvida rapidamente tem custo real — financeiro e de reputação. Prioridade de atendimento não é negociável." },
];
---

<BaseLayout
  title="Suporte Premium — infosaas®"
  description="Franquia mensal de horas dedicadas à evolução contínua de produtos já lançados — com a mesma equipe que construiu."
>

  <!-- HERO -->
  <section class="hero-suporte section">
    <div class="container">
      <span class="eyebrow eyebrow--accent">Suporte Premium</span>
      <h1 class="hero-headline">
        Lançar é o começo.<br>O produto precisa<br>continuar evoluindo.
      </h1>
      <p class="hero-sub">
        Franquia mensal de horas dedicadas à evolução contínua de produtos já lançados — com a mesma equipe que construiu, sem precisar explicar o projeto do zero para ninguém.
      </p>
      <a href="/contato" class="btn btn--primary btn--arrow">Fale com a gente</a>
    </div>
  </section>

  <div class="ticket-bar">
    <div class="container ticket-inner">
      <span class="ticket-label">Ticket</span>
      <span class="ticket-valor">A partir de R$ 8.000/mês · Franquia de 20h+</span>
    </div>
  </div>

  <!-- PARA QUEM -->
  <section class="section section--white">
    <div class="container">
      <span class="eyebrow">Para quem faz sentido</span>
      <h2 class="section-headline">Para quem não quer perder<br>o que foi construído.</h2>
      <div class="grid-3">
        {perfis.map(p => (
          <div class="item-card">
            <h3>{p.titulo}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- O QUE ESTÁ INCLUÍDO -->
  <section class="section">
    <div class="container">
      <span class="eyebrow">O que está incluído</span>
      <h2 class="section-headline">A mesma equipe.<br>A mesma qualidade.<br>Em regime de franquia mensal.</h2>
      <div class="franquia-destaque">
        <span class="franquia-num">20h+</span>
        <p>horas mensais dedicadas ao projeto — para melhorias, ajustes e evolução contínua.</p>
      </div>
      <div class="solucoes-lista">
        {inclusos.map((s, i) => (
          <div class="solucao-item">
            <span class="solucao-num">{String(i + 1).padStart(2, "0")}</span>
            <div>
              <h3 class="solucao-titulo">{s.titulo}</h3>
              <p class="solucao-desc">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- POR QUE IMPORTA -->
  <section class="section section--dark">
    <div class="container">
      <span class="eyebrow eyebrow--light">Por que isso importa</span>
      <h2 class="section-headline section-headline--light">Produto parado<br>é produto que regride.</h2>
      <p class="diferencial-intro">
        O mercado muda, a base de usuários cresce, surgem integrações novas. Sem evolução contínua, o que foi construído com cuidado começa a ficar para trás — e o custo de recontratar do zero, explicar o projeto e reconstruir contexto é muito maior do que manter.
      </p>
      <div class="grid-2 riscos-grid">
        {[
          { titulo: "O risco da pessoa-chave", desc: "Se existe alguém que sabe como tudo funciona — e só essa pessoa — qualquer ausência vira crise. O Suporte Premium distribui esse conhecimento para um time com registro auditável." },
          { titulo: "Custo de recontratar vs. custo de manter", desc: "Recontratar, repassar contexto e realinhar expectativas tem custo financeiro e de tempo. A franquia mensal mantém o time aquecido e o projeto evoluindo com previsibilidade." },
        ].map(r => (
          <div class="risco-item">
            <h3>{r.titulo}</h3>
            <p>{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    headline={"O produto que você\nconstruiu merece\ncontinuar crescendo."}
    sub="A conversa para o Suporte Premium começa com uma análise do projeto atual — para entender o volume de horas que faz sentido e o que está no roadmap."
    ctaLabel="Fale com a gente"
    ctaHref="/contato"
    variant="accent"
  />

  <section class="section section--white">
    <div class="container">
      <span class="eyebrow">Pode fazer sentido também</span>
      <div class="outras-grid">
        {[
          { label: "MVP Ágil", href: "/solucoes/mvp" },
          { label: "Soluções Enterprise", href: "/solucoes/enterprise" },
          { label: "Consultoria Estratégica", href: "/solucoes/consultoria" },
        ].map(o => (
          <a href={o.href} class="outra-card">{o.label} →</a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero-suporte { background: var(--branco-off); }
  .hero-headline {
    font-size: var(--fs-display); font-weight: 900;
    line-height: var(--lh-display); letter-spacing: var(--tr-tight);
    margin-block: var(--space-5);
  }
  .hero-sub {
    font-size: var(--fs-body-lg); color: var(--cinza-600);
    line-height: 1.65; margin-bottom: var(--space-6);
  }

  .ticket-bar { background: var(--laranja-soft); padding-block: var(--space-4); }
  .ticket-inner { display: flex; align-items: center; gap: var(--space-4); }
  .ticket-label { font-size: 12px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; color: var(--cinza-600); }
  .ticket-valor { font-size: 18px; font-weight: 700; color: var(--laranja); }

  .section-headline {
    font-size: var(--fs-h2); font-weight: 900; line-height: var(--lh-heading);
    letter-spacing: var(--tr-tight); margin-bottom: var(--space-8);
  }
  .section-headline--light { color: var(--fg-on-dark); }

  .item-card {
    background: var(--bg-elev); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: var(--space-6);
    display: flex; flex-direction: column; gap: var(--space-3);
  }
  .item-card h3 { font-size: var(--fs-h4); font-weight: 700; }
  .item-card p { font-size: 15px; color: var(--cinza-600); line-height: 1.6; }

  .franquia-destaque {
    display: flex; align-items: center; gap: var(--space-5);
    background: var(--laranja-soft); border: 1px solid rgba(255,61,0,0.2);
    border-radius: var(--radius-lg); padding: var(--space-6);
    margin-bottom: var(--space-8);
  }
  .franquia-num { font-size: 56px; font-weight: 900; color: var(--laranja); letter-spacing: var(--tr-tight); line-height: 1; white-space: nowrap; }
  .franquia-destaque p { font-size: var(--fs-body-lg); color: var(--cinza-700); line-height: 1.5; }

  .solucoes-lista { display: flex; flex-direction: column; }
  .solucao-item {
    display: flex; gap: var(--space-6); align-items: flex-start;
    padding-block: var(--space-6); border-bottom: 1px solid var(--border);
  }
  .solucao-item:last-child { border-bottom: 0; }
  .solucao-num { font-size: 13px; font-weight: 700; color: var(--laranja); min-width: 32px; padding-top: 3px; }
  .solucao-titulo { font-size: var(--fs-h4); font-weight: 700; margin-bottom: var(--space-2); }
  .solucao-desc { font-size: 15px; color: var(--cinza-600); line-height: 1.6; }

  .diferencial-intro {
    font-size: var(--fs-body-lg); color: var(--cinza-400);
    line-height: 1.65; margin-bottom: var(--space-8);
  }
  .riscos-grid { margin-top: 0; }
  .risco-item { display: flex; flex-direction: column; gap: var(--space-3); }
  .risco-item h3 { font-size: var(--fs-h4); font-weight: 700; color: var(--branco); }
  .risco-item p { font-size: 15px; color: var(--cinza-400); line-height: 1.6; }

  .outras-grid { display: flex; gap: var(--space-4); flex-wrap: wrap; margin-top: var(--space-5); }
  .outra-card {
    background: var(--branco-off); border: 1px solid var(--border);
    border-radius: var(--radius-md); padding: 12px 20px;
    font-size: 14px; font-weight: 600; color: var(--preto);
    transition: background var(--dur) var(--ease);
  }
  .outra-card:hover { background: var(--cinza-200); }
</style>
