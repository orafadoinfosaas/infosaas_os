---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroAccent from "../components/HeroAccent.astro";
import ProofBar from "../components/ProofBar.astro";
import CTASection from "../components/CTASection.astro";

const produtos = [
  {
    href: "/solucoes/mvp",
    ticket: "A partir de R$ 15.000/mês",
    nome: "MVP Ágil",
    desc: "Para validar uma ideia ou tirar um projeto do papel com velocidade, sem abrir mão de uma base que sustenta crescimento.",
  },
  {
    href: "/solucoes/enterprise",
    ticket: "A partir de R$ 20.000/mês",
    nome: "Soluções Enterprise",
    desc: "Plataformas, aplicativos e automações feitas sob medida para empresas com desafios complexos de integração, performance e conformidade.",
  },
  {
    href: "/solucoes/consultoria",
    ticket: "A partir de R$ 20.000/mês",
    nome: "Consultoria Estratégica",
    desc: "Mentoria executiva de até 90 dias com CEO e CMO — da validação do modelo de negócio ao MVP, passando por design e estratégia.",
  },
  {
    href: "/solucoes/suporte",
    ticket: "A partir de R$ 8.000/mês",
    nome: "Suporte Premium",
    desc: "Franquia mensal de horas para evolução contínua de produtos já lançados — com a mesma equipe que construiu.",
  },
];

const segmentos = [
  {
    href: "/segmentos/educacao",
    nome: "Educação",
    desc: "Especialistas no setor educacional desde 2017. Infoprodutores, faculdades e plataformas até corporações educacionais de grande porte.",
  },
  {
    href: "/segmentos/saude",
    nome: "Saúde",
    desc: "Presença no setor desde 2022. Clínicas, healthtechs, operadoras e empresas de gestão hospitalar.",
  },
  {
    href: "/segmentos/enterprise",
    nome: "Enterprise",
    desc: "Empresas de qualquer nicho com maturidade e complexidade operacional para uma parceria estratégica de alto impacto.",
  },
];

const diferenciais = [
  {
    titulo: "Equipe fixa em cada projeto",
    desc: "Antes de assinar, você sabe exatamente quem vai trabalhar no projeto. O mesmo time do início ao fim — você sabe com quem falar.",
  },
  {
    titulo: "Senioridade real, sem delegação oculta",
    desc: "Dez profissionais sênior. Nenhum freelancer ou subcontratado aparece no meio do projeto sem aviso.",
  },
  {
    titulo: "NPS 9.2",
    desc: "Não é número de marketing. É o que os clientes respondem quando perguntamos diretamente se indicariam a Infosaas.",
  },
];

const kpis = [
  { valor: "10 anos", label: "de mercado" },
  { valor: "10", label: "profissionais sênior" },
  { valor: "+R$ 10M", label: "faturados em tecnologia" },
  { valor: "NPS 9.2", label: "" },
];
---

<BaseLayout
  title="infosaas® — Studio de desenvolvimento inteligente para negócios"
  description="A Infosaas® é um studio que pensa junto com o negócio — da estratégia à entrega. Especialistas em Educação, Saúde e Enterprise."
>

  <HeroAccent
    headline={"O sistema que funciona hoje\né o mesmo que vai te travar\namanhã."}
    sub="A Infosaas® é um studio de desenvolvimento que pensa junto com o negócio — da estratégia à entrega, do início ao fim."
    ctaLabel="Fale com a gente"
    ctaHref="/contato"
    ctaSecondaryLabel="Conheça nossas soluções"
    ctaSecondaryHref="/solucoes/mvp"
  />

  <ProofBar />

  <!-- O QUE FAZEMOS -->
  <section class="section">
    <div class="container">
      <div class="posicionamento-grid">
        <div class="posicionamento-copy">
          <h2 class="posicionamento-headline">Não somos<br>uma software-house.</h2>
          <p>Somos um studio especializado em desenvolver e implementar soluções que fazem o negócio escalar com sustentabilidade. A diferença está na forma como trabalhamos: a mesma equipe sênior que concebe a estratégia é a que escreve o código e responde pelo resultado — do início ao fim.</p>
          <a href="/sobre" class="btn btn--dark btn--arrow">Conheça o studio</a>
        </div>
        <div class="pilares-grid">
          {[
            { titulo: "Estratégia antes do código", desc: "Antes de qualquer linha de código, entendemos o negócio. O que precisa ser construído, por quê, e qual o menor caminho para gerar resultado real." },
            { titulo: "Time sênior do início ao fim", desc: "Nenhum projeto passa por estagiário ou júnior. O mesmo time que propõe é o que executa — sem delegação para times desconhecidos no meio do caminho." },
            { titulo: "Parceiro, não fornecedor", desc: "Não recebemos escopo e sumimos. Fazemos parte do negócio do cliente enquanto o projeto vive — e às vezes muito depois disso." },
          ].map(p => (
            <div class="pilar-card">
              <h3 class="pilar-titulo">{p.titulo}</h3>
              <p class="pilar-desc">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- SEGMENTOS -->
  <section class="section section--white">
    <div class="container">
      <span class="eyebrow">Para quem trabalhamos</span>
      <h2 class="section-headline">Especialistas nos mercados<br>que exigem mais do que código.</h2>
      <div class="grid-3 segmentos-grid">
        {segmentos.map(s => (
          <a href={s.href} class="segmento-card">
            <h3>{s.nome}</h3>
            <p>{s.desc}</p>
            <span class="segmento-link">Ver soluções para {s.nome} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PRODUTOS -->
  <section class="section">
    <div class="container">
      <span class="eyebrow">Nossas soluções</span>
      <h2 class="section-headline">Cada projeto começa com<br>uma pergunta de negócio.</h2>
      <div class="grid-2 produtos-grid">
        {produtos.map(p => (
          <a href={p.href} class="produto-card">
            <span class="produto-ticket">{p.ticket}</span>
            <h3 class="produto-nome">{p.nome}</h3>
            <p class="produto-desc">{p.desc}</p>
            <span class="produto-cta">Saiba mais →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- DIFERENCIAL -->
  <section class="section section--dark">
    <div class="container">
      <h2 class="section-headline section-headline--light">
        Já foram queimados antes.<br>É por isso que a gente funciona diferente.
      </h2>
      <p class="diferencial-intro">
        A maioria dos nossos clientes chegou com uma cicatriz: um projeto entregue com atraso, fora do escopo, ou uma empresa que sumiu depois do pagamento. Entendemos essa desconfiança — e é exatamente por isso que trabalhamos com contratos claros, equipe fixa e transparência em cada sprint.
      </p>
      <div class="grid-3 diferencial-grid">
        {diferenciais.map(d => (
          <div class="diferencial-item">
            <h3 class="diferencial-titulo">{d.titulo}</h3>
            <p class="diferencial-desc">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- KPIS -->
  <section class="section section--white">
    <div class="container">
      <div class="kpis-grid">
        {kpis.map(k => (
          <div class="kpi-item">
            <span class="kpi-valor">{k.valor}</span>
            {k.label && <span class="kpi-label">{k.label}</span>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    headline={"O próximo passo\ncomeça com\numa conversa."}
    sub="Sem proposta genérica, sem template. A primeira conversa é para entender o negócio — não para empurrar solução."
    ctaLabel="Fale com a gente"
    ctaHref="/contato"
    variant="accent"
  />

</BaseLayout>

<style>
  .posicionamento-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-10);
    align-items: start;
  }
  .posicionamento-copy { display: flex; flex-direction: column; gap: var(--space-6); }
  .posicionamento-headline {
    font-size: var(--fs-display);
    font-weight: 900;
    line-height: var(--lh-display);
    letter-spacing: var(--tr-tight);
  }
  .posicionamento-copy p { font-size: var(--fs-body-lg); color: var(--cinza-600); line-height: 1.65; }

  .pilares-grid { display: flex; flex-direction: column; gap: var(--space-5); }
  .pilar-card { border-left: 2px solid var(--laranja); padding-left: var(--space-5); }
  .pilar-titulo { font-size: var(--fs-h4); font-weight: 700; margin-bottom: var(--space-2); }
  .pilar-desc { font-size: 15px; color: var(--cinza-600); line-height: 1.6; }

  .section-headline {
    font-size: var(--fs-h2);
    font-weight: 900;
    line-height: var(--lh-heading);
    letter-spacing: var(--tr-tight);
    margin-bottom: var(--space-8);
  }
  .section-headline--light { color: var(--fg-on-dark); }

  .segmentos-grid { margin-top: var(--space-7); }
  .segmento-card {
    display: flex; flex-direction: column; gap: var(--space-3);
    background: var(--branco-off); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: var(--space-6);
    transition: box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .segmento-card:hover { box-shadow: var(--shadow); transform: translateY(-2px); }
  .segmento-card h3 { font-size: var(--fs-h3); font-weight: 700; }
  .segmento-card p { font-size: 15px; color: var(--cinza-600); line-height: 1.6; flex: 1; }
  .segmento-link { font-size: 14px; font-weight: 600; color: var(--laranja); margin-top: auto; }

  .produtos-grid { margin-top: var(--space-7); }
  .produto-card {
    display: flex; flex-direction: column; gap: var(--space-3);
    background: var(--bg-elev); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: var(--space-7);
    transition: box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .produto-card:hover { box-shadow: var(--shadow); transform: translateY(-2px); }
  .produto-ticket { font-size: 13px; font-weight: 500; color: var(--laranja); }
  .produto-nome { font-size: var(--fs-h3); font-weight: 700; }
  .produto-desc { font-size: 15px; color: var(--cinza-600); line-height: 1.6; flex: 1; }
  .produto-cta { font-size: 14px; font-weight: 600; color: var(--preto); margin-top: auto; }

  .diferencial-intro {
    font-size: var(--fs-body-lg); color: var(--cinza-400);
    line-height: 1.65; margin-bottom: var(--space-8);
  }
  .diferencial-item { display: flex; flex-direction: column; gap: var(--space-3); }
  .diferencial-titulo { font-size: var(--fs-h4); font-weight: 700; color: var(--branco); }
  .diferencial-desc { font-size: 15px; color: var(--cinza-400); line-height: 1.6; }

  .kpis-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-6); }
  .kpi-item { display: flex; flex-direction: column; gap: var(--space-2); }
  .kpi-valor { font-size: clamp(32px, 4vw, 48px); font-weight: 900; color: var(--laranja); letter-spacing: var(--tr-tight); }
  .kpi-label { font-size: 14px; color: var(--cinza-600); }

  @media (max-width: 900px) {
    .posicionamento-grid { grid-template-columns: 1fr; gap: var(--space-8); }
    .kpis-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
