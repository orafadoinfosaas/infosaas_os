---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroStudio from '../components/sections/studio/HeroStudio.astro';
import AboutStudio from '../components/sections/studio/AboutStudio.astro';
import FoundersStudio from '../components/sections/studio/FoundersStudio.astro';
import SocialNumbersStudio from '../components/sections/studio/SocialNumbersStudio.astro';
import CTA from '../components/sections/shared/CTA.astro';
---

<BaseLayout
  title="O Studio — Infosaas®"
  description="Um studio criado por quem entende de negócio e código. A Infosaas® nasceu da combinação de profundidade técnica e visão de negócio para desenvolver e acelerar empresas."
>
  <Header />
  <main>
    <HeroStudio />
    <AboutStudio />
    <FoundersStudio />
    <SocialNumbersStudio />
    <CTA />
  </main>
  <Footer />
</BaseLayout>
