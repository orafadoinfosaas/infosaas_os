<style>
  .sn-ent {
    background-image: url('/Rectangle-22.webp');
    background-size: cover;
    background-position: center;
    padding: var(--space-9) 0;
    color: #fff;
  }

  .sn-ent-metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
    margin-bottom: var(--space-8);
  }

  .sn-ent-metric {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .sn-ent-number {
    font-size: clamp(26px, 3vw, 54px);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #fff;
  }

  .sn-ent-label {
    font-size: var(--fs-body);
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.4;
  }

  .sn-ent-logo-strip {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding-top: var(--space-5);
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    overflow: hidden;
  }

  .sn-ent-logo-label {
    font-size: 11px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.35);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
    flex-shrink: 0;
    line-height: 1.5;
    text-align: left;
  }

  .logo-track-wrap-ent {
    overflow: hidden;
    flex: 1;
    min-width: 0;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
  }

  .logo-track-ent {
    display: flex;
    align-items: center;
    gap: var(--space-7);
    width: max-content;
    animation: logos-scroll-ent 55s linear infinite;
  }

  .logo-track-ent img {
    height: 28px;
    width: 130px;
    object-fit: contain;
    object-position: center;
    display: block;
    filter: brightness(0) invert(1);
    opacity: 0.55;
    flex-shrink: 0;
  }

  .logo-track-ent img[src*="instituto-singular"],
  .logo-track-ent img[src*="phlebo"],
  .logo-track-ent img[src*="esporte-educa"],
  .logo-track-ent img[src*="pandora"],
  .logo-track-ent img[src*="G4"],
  .logo-track-ent img[src*="speake"] {
    height: 42px;
  }

  @keyframes logos-scroll-ent {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (max-width: 900px) {
    .sn-ent-metrics { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .sn-ent-metrics { grid-template-columns: 1fr; }
  }
</style>
