---
import 'intl-tel-input/styles';
---

<section class="contato">

  <div class="contato-left">
    <div class="contato-left-inner">
      <span class="contato-eyebrow">Fale com a gente</span>

      <h1 class="contato-headline">
        O primeiro contato é apenas uma conversa.
      </h1>

      <p class="contato-sub">
        Basta preencher o formulário e<br />entraremos em contato.
      </p>

      <a href="mailto:contato@infosaas.ai" class="contato-email">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <rect x="1" y="3" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/>
          <path d="M1 5.5L8 9.5L15 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        contato@infosaas.ai
      </a>
    </div>
  </div>

  <div class="contato-right">
    <form class="contato-form" action="#" novalidate>

      <div class="field">
        <label for="nome" class="field-label">Nome completo</label>
        <input id="nome" name="nome" type="text" class="field-input" placeholder="Seu nome completo" autocomplete="name" />
      </div>

      <div class="field">
        <label for="email" class="field-label">Seu melhor email</label>
        <input id="email" name="email" type="email" class="field-input" placeholder="email@empresa.com" autocomplete="email" />
      </div>

      <div class="field">
        <label for="whatsapp" class="field-label">Seu WhatsApp</label>
        <input id="whatsapp" name="whatsapp" type="tel" class="field-input" placeholder="00000-0000" autocomplete="tel" />
      </div>

      <div class="field-row">
        <div class="field">
          <label for="solucao" class="field-label">Solução de interesse</label>
          <div class="select-wrap">
            <select id="solucao" name="solucao" class="field-select">
              <option value="" disabled selected>Selecione</option>
              <option value="consultoria">Consultoria e Implementação</option>
              <option value="mvp">Criação de MVPs</option>
              <option value="enterprise">Enterprise</option>
              <option value="outro">Outro</option>
            </select>
            <svg class="select-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>

        <div class="field">
          <label for="segmento" class="field-label">Qual é o seu segmento?</label>
          <div class="select-wrap">
            <select id="segmento" name="segmento" class="field-select">
              <option value="" disabled selected>Selecione</option>
              <option value="educacao">Educação</option>
              <option value="saude">Saúde</option>
              <option value="enterprise">Enterprise</option>
              <option value="outro">Outro</option>
            </select>
            <svg class="select-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
      </div>

      <div class="field">
        <label for="empresa" class="field-label">Qual nome da empresa?</label>
        <input id="empresa" name="empresa" type="text" class="field-input" placeholder="Nome da sua empresa" autocomplete="organization" />
      </div>

      <div class="field">
        <label for="desafio" class="field-label">Qual é o seu desafio?</label>
        <textarea id="desafio" name="desafio" class="field-textarea" placeholder="Descreva brevemente o que você precisa resolver..." rows="4"></textarea>
      </div>

      <label class="checkbox-wrap">
        <input type="checkbox" name="privacidade" class="checkbox-input" />
        <span class="checkbox-box"></span>
        <span class="checkbox-label">
          Li e estou concordando com nossa
          <a href="/privacidade" class="checkbox-link">Política de Privacidade</a>.
        </span>
      </label>

      <button type="submit" class="btn-submit">Aplicar agora</button>

    </form>
  </div>

</section>

<style>
  .contato {
    display: grid;
    grid-template-columns: 5fr 6fr;
    min-height: calc(100vh - 72px);
  }

  /* ── Left column ─────────────────────────────────────── */
  .contato-left {
    background: var(--branco);
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: var(--space-9) clamp(32px, 4vw, 64px);
  }

  .contato-left-inner {
    max-width: 420px;
    width: 100%;
  }

  .contato-eyebrow {
    display: block;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cinza-500);
    margin-bottom: var(--space-5);
  }

  .contato-headline {
    font-size: clamp(36px, 4vw, 46px);
    font-weight: 900;
    line-height: 0.97;
    letter-spacing: -0.03em;
    color: #0A0A0A;
    text-wrap: unset;
    margin-bottom: var(--space-6);
  }

  .contato-sub {
    font-size: var(--fs-body);
    color: var(--cinza-600);
    line-height: var(--lh-body);
    margin-bottom: var(--space-6);
  }

  .contato-email {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--fs-body-sm);
    font-weight: 500;
    color: var(--cinza-600);
    border-bottom: none;
    transition: color var(--dur) var(--ease);
  }
  .contato-email:hover {
    color: var(--laranja);
  }
  .contato-email svg {
    flex-shrink: 0;
  }

  /* ── Right column (form) ──────────────────────────────── */
  .contato-right {
    background-image: url('/Rectangle-22.jpg');
    background-size: calc(100vw * 11 / 6) auto;
    background-position: left center;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: var(--space-9) clamp(32px, 4vw, 64px);
  }

  .contato-form {
    width: 100%;
    max-width: 520px;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  /* Fields */
  .field {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .field-label {
    font-size: var(--fs-body-sm);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.01em;
  }

  .field-input,
  .field-select,
  .field-textarea {
    width: 100%;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: var(--radius);
    padding: 12px 16px;
    font-size: var(--fs-body-sm);
    font-family: inherit;
    color: #fff;
    outline: none;
    transition: border-color var(--dur) var(--ease), background var(--dur) var(--ease);
    -webkit-appearance: none;
    appearance: none;
  }

  .field-input::placeholder,
  .field-textarea::placeholder {
    color: rgba(255, 255, 255, 0.28);
  }

  .field-input:focus,
  .field-select:focus,
  .field-textarea:focus {
    border-color: rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.10);
  }

  .field-textarea {
    resize: vertical;
    min-height: 100px;
    line-height: var(--lh-body);
  }

  /* Select wrapper */
  .select-wrap {
    position: relative;
  }

  .field-select {
    cursor: pointer;
    padding-right: 40px;
  }

  .field-select option {
    background: #3D0900;
    color: #fff;
  }

  .select-chevron {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(255, 255, 255, 0.45);
    pointer-events: none;
    flex-shrink: 0;
  }

  /* Checkbox */
  .checkbox-wrap {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    cursor: pointer;
  }

  .checkbox-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .checkbox-box {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    border: 1.5px solid rgba(255, 255, 255, 0.30);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.07);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
    transition: background var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }

  .checkbox-input:checked + .checkbox-box {
    background: var(--laranja);
    border-color: var(--laranja);
  }

  .checkbox-input:checked + .checkbox-box::after {
    content: '';
    display: block;
    width: 10px;
    height: 6px;
    border-left: 2px solid #fff;
    border-bottom: 2px solid #fff;
    transform: rotate(-45deg) translateY(-1px);
  }

  .checkbox-label {
    font-size: var(--fs-body-sm);
    color: rgba(255, 255, 255, 0.50);
    line-height: 1.5;
  }

  .checkbox-link {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: underline;
    text-underline-offset: 2px;
    border-bottom: none;
  }
  .checkbox-link:hover {
    color: #fff;
  }

  /* Submit button */
  .btn-submit {
    width: 100%;
    padding: 15px;
    background: var(--dark-surface);
    color: #fff;
    font-size: var(--fs-body);
    font-weight: 600;
    font-family: inherit;
    border: none;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: background var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }
  .btn-submit:hover {
    background: var(--laranja);
    box-shadow: var(--shadow-accent);
  }

  /* ── Responsive ───────────────────────────────────────── */
  @media (max-width: 900px) {
    .contato {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .contato-left {
      padding: var(--space-8) clamp(20px, 5vw, 48px);
    }
    .contato-right {
      padding: var(--space-8) clamp(20px, 5vw, 48px);
    }
  }

  @media (max-width: 560px) {
    .field-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<style is:global>
  /* intl-tel-input v29 — dark theme */
  .iti {
    width: 100%;
    --iti-border-color: transparent;
    --iti-hover-color: rgba(255, 255, 255, 0.07);
    --iti-country-selector-bg: #1e0704;
    --iti-icon-color: #fff;
  }

  /* Botão (bandeira + código) — .iti__selected-country */
  .iti__selected-country {
    background: rgba(255, 255, 255, 0.07);
    border-right: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: var(--radius) 0 0 var(--radius);
    outline: none;
    padding: 0 10px;
    gap: 6px;
  }
  .iti__selected-country:hover {
    background: rgba(255, 255, 255, 0.12);
  }

  .iti__selected-dial-code {
    color: rgba(255, 255, 255, 0.75);
    font-family: inherit;
    font-size: 13px;
  }

  /* Painel dropdown — .iti__country-selector */
  .iti__country-selector {
    background: #1e0704;
    border: none;
    border-radius: var(--radius);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.65);
    margin-top: 4px;
  }

  /* Campo de busca */
  .iti__search-input-wrapper {
    background: rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }
  .iti__search-input {
    background: transparent;
    color: #fff;
    font-family: inherit;
    font-size: 13px;
  }
  .iti__search-input::placeholder { color: rgba(255, 255, 255, 0.3); }
  .iti__search-input:focus        { outline: none; }

  .iti__search-icon-svg { stroke: rgba(255, 255, 255, 0.35); fill: none; }

  /* Itens da lista */
  .iti__country { padding: 9px 14px; }
  .iti__country:hover,
  .iti__country.iti__highlight { background: rgba(255, 255, 255, 0.07); }

  .iti__country-name { color: rgba(255, 255, 255, 0.85); }
  .iti__dial-code    { color: rgba(255, 255, 255, 0.4); }

  .iti__no-results {
    color: rgba(255, 255, 255, 0.4);
    padding: 12px 14px;
  }
</style>

<script>
  import intlTelInput from 'intl-tel-input/intlTelInputWithUtils';

  const input = document.getElementById('whatsapp') as HTMLInputElement | null;
  if (input) {
    const iti = intlTelInput(input, {
      initialCountry: 'br',
      countryOrder: ['br', 'pt', 'us', 'es', 'ar', 'mx'],
      separateDialCode: true,
      countrySearch: true,
      countryNameLocale: 'pt',
      uiTranslations: {
        searchPlaceholder: 'Buscar país',
        searchEmptyState: 'Nenhum país encontrado',
        selectedCountryAriaLabel: 'País selecionado',
        countryListAriaLabel: 'Lista de países',
        clearSearchAriaLabel: 'Limpar busca',
      },
    });

    input.closest('form')?.addEventListener('submit', () => {
      input.value = iti.getNumber();
    });
  }
</script>
