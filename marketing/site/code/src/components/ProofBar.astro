---
const clients = [
  "G4 Educação", "Comunidade Sem Codar", "Instituto Singular",
  "V4 Company", "Phlebo Academy", "Instituto Brasileiro de Educação em IA",
  "Pandora Treinamentos", "Esporte Educa", "AI Builders", "Fideliza PRO",
];
---

<section class="proof-bar section--white">
  <div class="container">
    <p class="eyebrow proof-eyebrow">Clientes que confiam</p>
    <div class="proof-list">
      {clients.map(c => <span class="proof-item">{c}</span>)}
    </div>
  </div>
</section>

<style>
  .proof-bar { padding-block: var(--space-7); }
  .proof-eyebrow { margin-bottom: var(--space-6); }

  .proof-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-6);
  }

  .proof-item {
    font-size: 13px;
    font-weight: 500;
    color: var(--cinza-500);
    white-space: nowrap;
    letter-spacing: 0.01em;
  }
</style>
