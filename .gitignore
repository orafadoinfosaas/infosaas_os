# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables — todos os .env são locais e podem conter secrets;
# os .env.example (sem valores) vão pro repo como documentação.
.env
.env.*
!.env.example
!*.env.example

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# AI assistants
.gemini/
.tmp.driveupload/

# Claude Code — só os slash commands vão pro repo;
# settings.local.json e tudo mais ficam locais (têm secrets/estado por máquina).
.claude/*
!.claude/commands/
!.claude/commands/**

# MCP — settings locais do Claude Code com tokens (vamos sempre via .env)
ferramentas/mcps/.claude.json

# Vídeos: footage e renders são binários pesados (>100MB) — não versionar.
# O conteúdo (caption.md, content.json) na raiz da pasta do vídeo continua versionado;
# a mídia vai pro R2/Nextcloud, não pro git.
marketing/conteudo/instagram/videos/**/assets/
