<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" aria-label="Infosaas — página inicial">
        <img src="/logos/logo-branco.svg" alt="infosaas" width="120" height="28" />
      </a>
      <p class="footer-tagline">Um studio que pensa e cresce junto com o seu negócio.</p>
    </div>

    <div class="footer-col">
      <h5 class="footer-col-title">Soluções</h5>
      <ul>
        <li><a href="/solucoes/mvp">MVP Ágil</a></li>
        <li><a href="/solucoes/consultoria">Consultoria Estratégica</a></li>
        <li><a href="/solucoes/enterprise">Soluções Enterprise</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h5 class="footer-col-title">Segmentos</h5>
      <ul>
        <li><a href="/segmentos/educacao">Educação</a></li>
        <li><a href="/segmentos/saude">Saúde</a></li>
        <li><a href="/segmentos/enterprise">Enterprise</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h5 class="footer-col-title">Infosaas®</h5>
      <ul>
        <li><a href="/studio">O Studio</a></li>
        <li><a href="/contato">Fale com a gente</a></li>
        <li><a href="/privacidade">Privacidade</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>© 2026 Infosaas®. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--footer-bg);
    color: rgba(255, 255, 255, 0.65);
  }

  /* 2fr para a brand + 1fr para cada coluna de links */
  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-6);
    padding-top: var(--space-9);
    padding-bottom: var(--space-9);
  }

  .footer-brand img {
    display: block;
    height: 28px;
    width: auto;
  }

  .footer-tagline {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
    margin-top: var(--space-4);
    max-width: 200px;
  }

  .footer-col-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: var(--space-4);
  }

  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-col a {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.65);
    display: block;
    transition: color var(--dur) var(--ease);
    border-bottom: none;
  }
  .footer-col a:hover { color: #fff; }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .footer-bottom .container {
    padding-top: var(--space-5);
    padding-bottom: var(--space-5);
  }
  .footer-bottom p {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 960px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 560px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
