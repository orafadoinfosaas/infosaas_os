---
const solucoes = [
  { label: "MVP Ágil", href: "/solucoes/mvp" },
  { label: "Soluções Enterprise", href: "/solucoes/enterprise" },
  { label: "Consultoria Estratégica", href: "/solucoes/consultoria" },
  { label: "Suporte Premium", href: "/solucoes/suporte" },
];

const segmentos = [
  { label: "Educação", href: "/segmentos/educacao" },
  { label: "Saúde", href: "/segmentos/saude" },
  { label: "Enterprise", href: "/segmentos/enterprise" },
];

const institucional = [
  { label: "O studio", href: "/sobre" },
  { label: "Cases", href: "/cases" },
  { label: "Fale com a gente", href: "/contato" },
];
---

<footer class="site-footer">
  <div class="container footer-inner">

    <div class="footer-brand">
      <a href="/" aria-label="infosaas® — home">
        <img src="/logos/logo-branco.svg" alt="infosaas®" width="120" height="32" />
      </a>
      <p class="footer-tagline">
        Um studio que pensa junto com o negócio — da estratégia à entrega.
      </p>
      <a href="mailto:sistemas@infosaas.ai" class="footer-email">sistemas@infosaas.ai</a>
    </div>

    <nav class="footer-nav" aria-label="Soluções">
      <p class="footer-heading">Soluções</p>
      <ul>
        {solucoes.map(l => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>

    <nav class="footer-nav" aria-label="Segmentos">
      <p class="footer-heading">Segmentos</p>
      <ul>
        {segmentos.map(l => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>

    <nav class="footer-nav" aria-label="Institucional">
      <p class="footer-heading">Infosaas®</p>
      <ul>
        {institucional.map(l => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>

  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>© {new Date().getFullYear()} infosaas®. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--preto);
    color: var(--fg-on-dark);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-8);
    padding-block: var(--space-9);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .footer-tagline {
    font-size: 15px;
    color: var(--cinza-400);
    line-height: 1.6;
    max-width: 280px;
  }

  .footer-email {
    font-size: 14px;
    color: var(--cinza-400);
    transition: color var(--dur) var(--ease);
  }
  .footer-email:hover { color: var(--branco); }

  .footer-heading {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cinza-500);
    margin-bottom: var(--space-4);
  }

  .footer-nav ul { list-style: none; display: flex; flex-direction: column; gap: var(--space-3); }
  .footer-nav a {
    font-size: 14px;
    color: var(--cinza-400);
    transition: color var(--dur) var(--ease);
  }
  .footer-nav a:hover { color: var(--branco); }

  .footer-bottom {
    border-top: 1px solid var(--cinza-700);
  }
  .footer-bottom-inner {
    padding-block: var(--space-5);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .footer-bottom p {
    font-size: 13px;
    color: var(--cinza-600);
  }

  @media (max-width: 860px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-7);
    }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 480px) {
    .footer-inner { grid-template-columns: 1fr; }
  }
</style>
