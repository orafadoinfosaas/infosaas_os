<section class="social-numbers">
  <div class="container">
    <div class="sn-inner">
      <img src="/barra-lateral-vertical-mono.svg" class="sn-bar" alt="" aria-hidden="true" />

      <div class="sn-content">

        <div class="sn-quote-block">
          <img src="/aspas.svg" class="sn-aspas" alt="" aria-hidden="true" />
          <h2 class="sn-headline">
            Desde quando surgimos, somos parceiros de longo prazo.
          </h2>
          <p class="sn-body">
            Nossos clientes enterprises costumam ficar. O relacionamento não termina com a entrega,
            ele evolui para suporte, novas frentes e projetos. Isso exige um nível de confiança que
            só se constrói com <strong>transparência, cumprimento de prazo e um time que o cliente
            conhece pelo nome.</strong>
          </p>
        </div>

        <div class="sn-diferenciais">
          <div class="sn-dif">
            <h4>Equipe Fixa</h4>
            <p>
              Antes de assinar, você sabe exatamente quem vai trabalhar no projeto.
              O mesmo time do início ao fim — você sabe com quem fala.
            </p>
          </div>
          <div class="sn-dif">
            <h4>Senioridade Evidente</h4>
            <p>
              Profissionais sêniors. Nenhum freelancer ou subcontratado aparece no meio do
              projeto por acaso.
            </p>
          </div>
          <div class="sn-dif">
            <h4>NPS Visceral Acima de 9.0</h4>
            <p>
              Não é número de marketing. É o que os clientes respondem quando perguntamos
              diretamente se indicariam a Infosaas®.
            </p>
          </div>
        </div>

        <div class="sn-metrics">
          <div class="sn-metric">
            <span class="sn-number">10 anos</span>
            <span class="sn-label">de experiência de mercado</span>
          </div>
          <div class="sn-metric">
            <span class="sn-number">10</span>
            <span class="sn-label">profissionais sêniors</span>
          </div>
          <div class="sn-metric">
            <span class="sn-number">R$ 60M+</span>
            <span class="sn-label">Receita gerada para clientes</span>
          </div>
          <div class="sn-metric">
            <span class="sn-number">9.2</span>
            <span class="sn-label">de NPS dos nossos clientes</span>
          </div>
        </div>

        <div class="sn-logo-strip">
          <span class="sn-logo-label">Confiado por<br />grandes empresas</span>
          <div class="logo-track-wrap">
            <div class="logo-track">
              <!-- Set 1 -->
              <img src="/logos-clientes/G4.png"                 alt="G4"                   />
              <img src="/logos-clientes/Group.png"              alt="V4 Company"           />
              <img src="/logos-clientes/Frame.png"              alt="microsaas"            />
              <img src="/logos-clientes/Frame-2.png"            alt="Sem Codar"            />
              <img src="/logos-clientes/Group 10067.png"        alt="Turbox"               />
              <img src="/logos-clientes/Group 10006.png"        alt="Rufy"                 />
              <img src="/logos-clientes/Ativo 13 1.png"         alt="Nulink"               />
              <img src="/logos-clientes/Frame-1.png"            alt="AI Builders"          />
              <img src="/logos-clientes/instituto-singular.png" alt="Instituto Singular"   />
              <img src="/logos-clientes/speake.png"             alt="Speake"               />
              <img src="/logos-clientes/phlebo.png"             alt="Phlebo Academy"       />
              <img src="/logos-clientes/pandora.png"            alt="Pandora Treinamentos" />
              <img src="/logos-clientes/esporte-educa.png"      alt="Esporte Educa"        />
              <img src="/logos-clientes/image 11.png"           alt="Fideliza Pro"         />
              <img src="/logos-clientes/image 12.png"           alt="iDoméstica"           />
              <!-- Set 2 — duplicado para loop seamless -->
              <img src="/logos-clientes/G4.png"                 alt="G4"                   />
              <img src="/logos-clientes/Group.png"              alt="V4 Company"           />
              <img src="/logos-clientes/Frame.png"              alt="microsaas"            />
              <img src="/logos-clientes/Frame-2.png"            alt="Sem Codar"            />
              <img src="/logos-clientes/Group 10067.png"        alt="Turbox"               />
              <img src="/logos-clientes/Group 10006.png"        alt="Rufy"                 />
              <img src="/logos-clientes/Ativo 13 1.png"         alt="Nulink"               />
              <img src="/logos-clientes/Frame-1.png"            alt="AI Builders"          />
              <img src="/logos-clientes/instituto-singular.png" alt="Instituto Singular"   />
              <img src="/logos-clientes/speake.png"             alt="Speake"               />
              <img src="/logos-clientes/phlebo.png"             alt="Phlebo Academy"       />
              <img src="/logos-clientes/pandora.png"            alt="Pandora Treinamentos" />
              <img src="/logos-clientes/esporte-educa.png"      alt="Esporte Educa"        />
              <img src="/logos-clientes/image 11.png"           alt="Fideliza Pro"         />
              <img src="/logos-clientes/image 12.png"           alt="iDoméstica"           />
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .social-numbers {
    background-image: url('/Rectangle-22.jpg');
    background-size: cover;
    background-position: center;
    padding: var(--space-9) 0;
    color: #fff;
  }

  .sn-inner {
    display: flex;
    align-items: flex-start;
    gap: 20px;
  }

  .sn-bar {
    width: 10px;
    height: auto;
    flex-shrink: 0;
    display: block;
  }

  .sn-content {
    flex: 1;
    min-width: 0;
  }

  .sn-quote-block {
    margin-bottom: var(--space-8);
  }

  .sn-aspas {
    display: block;
    width: 60px;
    height: auto;
    margin-bottom: var(--space-5);
  }

  .sn-headline {
    font-size: clamp(36px, 4vw, 56px);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #fff;
    margin-bottom: var(--space-5);
  }

  .sn-body {
    font-size: var(--fs-body);
    color: rgba(255, 255, 255, 0.75);
    line-height: var(--lh-body);
    max-width: 700px;
  }
  .sn-body strong {
    color: #fff;
    font-weight: 600;
  }

  .sn-diferenciais {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1.5px solid rgba(255, 255, 255, 0.35);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-8);
  }

  .sn-dif {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .sn-dif:not(:last-child) {
    border-right: 1.5px solid rgba(255, 255, 255, 0.35);
  }

  .sn-dif h4 {
    font-size: var(--fs-h4);
    font-weight: 700;
    color: #fff;
    line-height: var(--lh-tight);
  }

  .sn-dif p {
    font-size: var(--fs-body-sm);
    color: rgba(255, 255, 255, 0.65);
    line-height: var(--lh-body);
  }

  .sn-metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
    margin-bottom: var(--space-8);
  }

  .sn-metric {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .sn-number {
    font-size: clamp(26px, 3vw, 54px);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #fff;
  }

  .sn-label {
    font-size: var(--fs-body);
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.4;
  }

  .sn-logo-strip {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding-top: var(--space-5);
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    overflow: hidden;
  }

  .sn-logo-label {
    font-size: 11px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.35);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
    flex-shrink: 0;
    line-height: 1.5;
    text-align: left;
  }

  .logo-track-wrap {
    overflow: hidden;
    flex: 1;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
  }

  .logo-track {
    display: flex;
    align-items: center;
    gap: var(--space-7);
    width: max-content;
    animation: logos-scroll 55s linear infinite;
  }

  .logo-track img {
    height: 28px;
    width: 130px;
    object-fit: contain;
    object-position: center;
    display: block;
    filter: brightness(0) invert(1);
    opacity: 0.55;
    flex-shrink: 0;
  }

  .logo-track img[src*="instituto-singular"],
  .logo-track img[src*="phlebo"],
  .logo-track img[src*="esporte-educa"],
  .logo-track img[src*="pandora"],
  .logo-track img[src*="G4"],
  .logo-track img[src*="speake"] {
    height: 42px;
  }

  @keyframes logos-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (max-width: 900px) {
    .sn-bar { display: none; }
    .sn-diferenciais { grid-template-columns: 1fr; }
    .sn-dif:not(:last-child) {
      border-right: none;
      border-bottom: 1.5px solid rgba(255, 255, 255, 0.35);
    }
    .sn-metrics { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .sn-metrics { grid-template-columns: 1fr; }
  }
</style>
