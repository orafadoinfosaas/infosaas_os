---
interface Props {
  eyebrow?: string;
  headline: string;
  sub?: string;
  ctaLabel?: string;
  ctaHref?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryHref?: string;
  dark?: boolean;
}

const {
  eyebrow,
  headline,
  sub,
  ctaLabel = "Fale com a gente",
  ctaHref = "/contato",
  ctaSecondaryLabel,
  ctaSecondaryHref,
  dark = false,
} = Astro.props;
---

<section class={`hero ${dark ? "hero--dark" : "hero--accent"}`}>
  <div class="symbol-overlay">
    <img src="/logos/simbolo-branco.svg" alt="" aria-hidden="true" />
  </div>
  <div class="container hero-inner">
    {eyebrow && <span class="eyebrow eyebrow--light">{eyebrow}</span>}
    <h1 class="hero-headline" set:html={headline.replace(/\n/g, "<br>")} />
    {sub && <p class="hero-sub">{sub}</p>}
    <div class="hero-actions">
      <a href={ctaHref} class="btn btn--white btn--arrow">{ctaLabel}</a>
      {ctaSecondaryLabel && ctaSecondaryHref && (
        <a href={ctaSecondaryHref} class="btn btn--ghost-light">{ctaSecondaryLabel}</a>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-10);
  }
  .hero--accent { background: var(--laranja); }
  .hero--dark   { background: var(--preto); }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .hero-headline {
    font-size: var(--fs-display);
    font-weight: 900;
    line-height: var(--lh-display);
    letter-spacing: var(--tr-tight);
    color: var(--branco);
    text-wrap: balance;
  }

  .hero-sub {
    font-size: var(--fs-body-lg);
    color: rgba(255,255,255,0.8);
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding-top: var(--space-3);
  }

  @media (max-width: 640px) {
    .hero { padding-block: var(--space-8); }
    .hero-headline { font-size: clamp(36px, 10vw, 56px); }
  }
</style>
