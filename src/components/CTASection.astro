---
interface Props {
  headline: string;
  sub?: string;
  ctaLabel?: string;
  ctaHref?: string;
  variant?: "accent" | "dark" | "light";
}

const {
  headline,
  sub,
  ctaLabel = "Fale com a gente",
  ctaHref = "/contato",
  variant = "accent",
} = Astro.props;

const btnClass = variant === "accent" ? "btn--white btn--arrow" : "btn--primary btn--arrow";
---

<section class={`cta-section section section--${variant === "accent" ? "accent" : variant === "dark" ? "dark" : ""}`}>
  <div class="container cta-inner">
    <h2 class="cta-headline" set:html={headline.replace(/\n/g, "<br>")} />
    {sub && <p class="cta-sub">{sub}</p>}
    <a href={ctaHref} class={`btn ${btnClass}`}>{ctaLabel}</a>
  </div>
</section>

<style>
  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-6);
  }

  .cta-headline {
    font-size: var(--fs-display);
    font-weight: 900;
    line-height: var(--lh-display);
    letter-spacing: var(--tr-tight);
    text-wrap: balance;
  }

  .cta-sub {
    font-size: var(--fs-body-lg);
    line-height: 1.6;
    opacity: 0.85;
  }

  .section--accent .cta-headline,
  .section--accent .cta-sub { color: var(--branco); }
  .section--dark .cta-headline,
  .section--dark .cta-sub { color: var(--fg-on-dark); }

  @media (max-width: 640px) {
    .cta-headline { font-size: clamp(32px, 9vw, 52px); }
  }
</style>
