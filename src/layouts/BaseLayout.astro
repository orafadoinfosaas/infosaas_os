---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Infosaas® — Studio de Estratégia, Negócios & Tecnologia",
  description = "A Infosaas® é um studio de desenvolvimento e aceleração de negócios.",
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
