---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Política de Privacidade — Infosaas®"
  description="Saiba como a Infosaas® coleta, usa e protege seus dados pessoais, em conformidade com a LGPD."
>
  <Header />
  <main>

    <section class="priv-hero">
      <div class="container">
        <p class="priv-eyebrow">Transparência & Privacidade</p>
        <h1 class="priv-title">Política de Privacidade</h1>
        <p class="priv-meta">Última atualização: 26 de maio de 2026</p>
      </div>
    </section>

    <section class="priv-body">
      <div class="container priv-layout">

        <nav class="priv-toc" aria-label="Índice">
          <p class="toc-label">Nesta página</p>
          <ol class="toc-list">
            <li><a href="#controlador">1. Quem somos</a></li>
            <li><a href="#dados">2. Dados coletados</a></li>
            <li><a href="#finalidade">3. Finalidade e base legal</a></li>
            <li><a href="#cookies">4. Cookies e rastreadores</a></li>
            <li><a href="#compartilhamento">5. Compartilhamento</a></li>
            <li><a href="#retencao">6. Retenção</a></li>
            <li><a href="#direitos">7. Seus direitos (LGPD)</a></li>
            <li><a href="#consentimento">8. Gerenciar consentimento</a></li>
            <li><a href="#contato">9. Contato</a></li>
          </ol>
        </nav>

        <article class="priv-content">

          <section id="controlador" class="priv-section">
            <h2>1. Quem somos</h2>
            <p>
              A <strong>Infosaas®</strong> (Infosaas Tecnologia Ltda.) é a controladora dos dados pessoais
              coletados neste site. Atuamos como um studio especializado em estratégia, negócios e tecnologia,
              com o compromisso de tratar seus dados com responsabilidade e transparência.
            </p>
            <p>
              Encarregado de dados (DPO):<br />
              <a href="mailto:privacidade@infosaas.ai">privacidade@infosaas.ai</a>
            </p>
          </section>

          <section id="dados" class="priv-section">
            <h2>2. Dados coletados</h2>
            <p>Coletamos dados <strong>apenas mediante seu consentimento explícito</strong>. Se você recusar os cookies, nenhum dado de rastreamento é capturado.</p>
            <p>Quando você aceita os cookies de analytics, podemos coletar:</p>
            <ul>
              <li>Páginas visitadas e tempo de permanência</li>
              <li>Origem do acesso (busca orgânica, redes sociais, link direto)</li>
              <li>Tipo de dispositivo, sistema operacional e navegador</li>
              <li>País e cidade aproximados (via IP anonimizado)</li>
              <li>Interações com elementos da página (cliques, rolagem)</li>
            </ul>
            <p>
              Não coletamos nome, e-mail, CPF ou qualquer dado pessoal identificável por meio de cookies.
              Os dados do formulário de contato são tratados separadamente e coletados apenas quando você
              os preenche voluntariamente.
            </p>
          </section>

          <section id="finalidade" class="priv-section">
            <h2>3. Finalidade e base legal</h2>
            <div class="priv-table-wrap">
              <table class="priv-table">
                <thead>
                  <tr>
                    <th>Finalidade</th>
                    <th>Base legal (LGPD)</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>Analytics de navegação e melhoria do site</td>
                    <td>Consentimento — Art. 7º, I</td>
                  </tr>
                  <tr>
                    <td>Atendimento ao contato e orçamentos</td>
                    <td>Execução de contrato / Legítimo interesse — Art. 7º, V e IX</td>
                  </tr>
                  <tr>
                    <td>Cumprimento de obrigação legal</td>
                    <td>Obrigação legal — Art. 7º, II</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>

          <section id="cookies" class="priv-section">
            <h2>4. Cookies e rastreadores</h2>
            <p>
              Utilizamos cookies de terceiros <strong>somente após seu consentimento</strong>.
              Os scripts não são carregados antes de você aceitar o aviso exibido ao acessar o site.
            </p>
            <div class="priv-table-wrap">
              <table class="priv-table">
                <thead>
                  <tr>
                    <th>Ferramenta</th>
                    <th>Fornecedor</th>
                    <th>Finalidade</th>
                    <th>Tipo</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>Google Tag Manager</td>
                    <td>Google LLC</td>
                    <td>Gerenciamento de tags de analytics e marketing</td>
                    <td>Analytics / Marketing</td>
                  </tr>
                  <tr>
                    <td>Google Analytics 4</td>
                    <td>Google LLC</td>
                    <td>Análise de tráfego e comportamento de navegação</td>
                    <td>Analytics</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <p>
              O Google Analytics é configurado com anonimização de IP. Os dados são processados
              nos servidores do Google nos termos da sua
              <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Política de Privacidade</a>.
            </p>
          </section>

          <section id="compartilhamento" class="priv-section">
            <h2>5. Compartilhamento de dados</h2>
            <p>Seus dados de navegação (quando coletados) são compartilhados com:</p>
            <ul>
              <li><strong>Google LLC</strong> — para fins de analytics, com dados anonimizados.</li>
            </ul>
            <p>
              Não vendemos, alugamos ou cedemos seus dados a terceiros para fins comerciais.
              O compartilhamento ocorre estritamente nas condições descritas acima ou por exigência legal.
            </p>
          </section>

          <section id="retencao" class="priv-section">
            <h2>6. Retenção de dados</h2>
            <p>
              Os dados de analytics são retidos pelo Google Analytics por até <strong>14 meses</strong>,
              conforme configuração padrão. Após esse período, são excluídos automaticamente.
            </p>
            <p>
              Dados fornecidos via formulário de contato são retidos pelo tempo necessário para
              responder à solicitação e, se aplicável, pelo prazo legal exigido.
            </p>
          </section>

          <section id="direitos" class="priv-section">
            <h2>7. Seus direitos (LGPD)</h2>
            <p>A Lei Geral de Proteção de Dados (Lei 13.709/2018) garante a você os seguintes direitos:</p>
            <ul>
              <li><strong>Confirmação e acesso</strong> — saber se tratamos seus dados e obter uma cópia.</li>
              <li><strong>Correção</strong> — solicitar a correção de dados incompletos ou desatualizados.</li>
              <li><strong>Anonimização, bloqueio ou eliminação</strong> — de dados desnecessários ou excessivos.</li>
              <li><strong>Portabilidade</strong> — receber seus dados em formato estruturado.</li>
              <li><strong>Eliminação</strong> — dos dados tratados com base no seu consentimento.</li>
              <li><strong>Informação</strong> — sobre com quem compartilhamos seus dados.</li>
              <li><strong>Revogação do consentimento</strong> — a qualquer momento, sem ônus.</li>
              <li><strong>Reclamação à ANPD</strong> — junto à Autoridade Nacional de Proteção de Dados.</li>
            </ul>
            <p>
              Para exercer qualquer desses direitos, entre em contato pelo e-mail
              <a href="mailto:privacidade@infosaas.ai">privacidade@infosaas.ai</a>.
              Responderemos em até 15 dias úteis.
            </p>
          </section>

          <section id="consentimento" class="priv-section">
            <h2>8. Gerenciar seu consentimento</h2>
            <p>
              Você pode revogar ou alterar sua escolha de cookies a qualquer momento.
              Para isso, clique no botão abaixo para limpar sua preferência — o aviso de cookies
              será exibido novamente na próxima vez que você acessar o site.
            </p>
            <button id="reset-consent" class="btn-reset-consent">
              Redefinir preferências de cookies
            </button>
            <p class="priv-note">
              Após clicar, recarregue a página para que o aviso de cookies apareça novamente.
            </p>
          </section>

          <section id="contato" class="priv-section">
            <h2>9. Contato</h2>
            <p>
              Dúvidas sobre esta Política de Privacidade ou sobre o tratamento dos seus dados?
              Fale com nosso encarregado de dados:
            </p>
            <p>
              <strong>Infosaas® — Encarregado de Proteção de Dados</strong><br />
              <a href="mailto:privacidade@infosaas.ai">privacidade@infosaas.ai</a>
            </p>
            <p>
              Esta política pode ser atualizada periodicamente. A data de última atualização
              está indicada no topo desta página.
            </p>
          </section>

        </article>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────────────── */
  .priv-hero {
    background: var(--bg-hero);
    padding: calc(72px + var(--space-9)) 0 var(--space-8);
  }

  .priv-eyebrow {
    font-size: var(--fs-eyebrow);
    font-weight: 500;
    letter-spacing: var(--tr-eyebrow);
    text-transform: uppercase;
    color: var(--laranja);
    margin-bottom: var(--space-4);
  }

  .priv-title {
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 900;
    color: var(--branco-off);
    line-height: var(--lh-display);
    letter-spacing: var(--tr-tight);
    margin-bottom: var(--space-4);
  }

  .priv-meta {
    font-size: var(--fs-body-sm);
    color: rgba(255, 255, 255, 0.4);
  }

  /* ── Layout ─────────────────────────────────────────────── */
  .priv-body {
    background: var(--branco-off);
    padding: var(--space-9) 0;
  }

  .priv-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--space-9);
    align-items: start;
  }

  /* ── ToC ─────────────────────────────────────────────────── */
  .priv-toc {
    position: sticky;
    top: calc(72px + var(--space-6));
  }

  .toc-label {
    font-size: var(--fs-eyebrow);
    font-weight: 700;
    letter-spacing: var(--tr-eyebrow);
    text-transform: uppercase;
    color: var(--cinza-400);
    margin-bottom: var(--space-4);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border-left: 2px solid var(--cinza-300);
    padding-left: var(--space-4);
  }

  .toc-list a {
    font-size: var(--fs-body-sm);
    color: var(--cinza-500);
    transition: color var(--dur) var(--ease);
    line-height: 1.5;
  }
  .toc-list a:hover { color: var(--laranja); }

  /* ── Content ────────────────────────────────────────────── */
  .priv-content {
    min-width: 0;
  }

  .priv-section {
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--cinza-200);
    margin-bottom: var(--space-8);
  }
  .priv-section:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .priv-section h2 {
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--cinza-900);
    margin-bottom: var(--space-5);
  }

  .priv-section p {
    font-size: var(--fs-body);
    color: var(--cinza-600);
    line-height: var(--lh-body);
    margin-bottom: var(--space-4);
  }
  .priv-section p:last-child { margin-bottom: 0; }

  .priv-section ul {
    padding-left: var(--space-5);
    margin: var(--space-4) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .priv-section li {
    font-size: var(--fs-body);
    color: var(--cinza-600);
    line-height: var(--lh-body);
  }

  .priv-section a {
    color: var(--laranja);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .priv-section a:hover { color: var(--laranja-hover); }

  .priv-note {
    font-size: var(--fs-body-sm) !important;
    color: var(--cinza-400) !important;
    margin-top: var(--space-3) !important;
  }

  /* ── Table ──────────────────────────────────────────────── */
  .priv-table-wrap {
    overflow-x: auto;
    margin: var(--space-5) 0;
    border-radius: var(--radius);
    border: 1px solid var(--cinza-200);
  }

  .priv-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-body-sm);
  }

  .priv-table th {
    background: var(--cinza-100);
    color: var(--cinza-700);
    font-weight: 600;
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid var(--cinza-200);
    white-space: nowrap;
  }

  .priv-table td {
    padding: 12px 16px;
    color: var(--cinza-600);
    border-bottom: 1px solid var(--cinza-200);
    vertical-align: top;
    line-height: var(--lh-body);
  }

  .priv-table tr:last-child td { border-bottom: none; }

  /* ── Reset consent button ───────────────────────────────── */
  .btn-reset-consent {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: var(--space-4);
    padding: 11px 24px;
    background: transparent;
    border: 1.5px solid var(--cinza-300);
    border-radius: var(--radius-pill);
    color: var(--cinza-600);
    font-size: var(--fs-body-sm);
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: border-color var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .btn-reset-consent:hover {
    border-color: var(--laranja);
    color: var(--laranja);
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 900px) {
    .priv-layout {
      grid-template-columns: 1fr;
    }
    .priv-toc {
      position: static;
      border: 1px solid var(--cinza-200);
      border-radius: var(--radius);
      padding: var(--space-5);
      background: var(--branco);
    }
  }

  @media (max-width: 768px) {
    .priv-hero { padding-top: calc(72px + var(--space-8)); }
    .priv-body { padding: var(--space-8) 0; }
  }
</style>

<script>
  document.getElementById('reset-consent')?.addEventListener('click', () => {
    localStorage.removeItem('infosaas_consent');
    alert('Preferências de cookies removidas. Recarregue a página para ver o aviso novamente.');
  });
</script>
