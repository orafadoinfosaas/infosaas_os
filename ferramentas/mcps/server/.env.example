# MCP server — Infosaas OS (Fase 1: single-tenant + bearer)
# Copie para .env.local nesta pasta e preencha. .env.local é gitignored
# (o .gitignore da raiz cobre .env.*) — NUNCA commitar token real.

# Token bearer que o conector do Claude envia no header Authorization.
# Gere um valor forte (ex.: `openssl rand -hex 32`).
MCP_TOKEN=

# Porta HTTP local do MCP (fica atrás do reverse proxy / Nginx / Caddy).
PORT=8787

# Tenant fixo na Fase 1 (single-tenant: o cliente é você).
TENANT_ID=infosaas

# --- Storage (Fase 2) ---
# Se NEXTCLOUD_URL estiver definido, o servidor usa o backend WebDAV (Nextcloud/
# Storage Share). Senão, usa o backend LOCAL (dev) lendo o repo.
#
# Produção (WebDAV — Hetzner Storage Share):
#   NEXTCLOUD_URL=https://<instancia>.your-storageshare.de/remote.php/dav/files/<usuario>/
#   NEXTCLOUD_USER=<usuario>
#   NEXTCLOUD_PASS=<senha-de-app>     # secret — gerar em Configurações → Segurança
#   NEXTCLOUD_BASE=clientes           # pasta-raiz dos tenants (default: clientes)
NEXTCLOUD_URL=
NEXTCLOUD_USER=
NEXTCLOUD_PASS=
NEXTCLOUD_BASE=clientes

# Backend LOCAL (dev): raiz das pastas de cliente. Vazio = lê o dna/ deste repo.
CLIENTS_ROOT=

# Fase 2 (tools semânticas): URL do app de conteúdo na MESMA VPS. Vazio por ora.
APP_URL=
