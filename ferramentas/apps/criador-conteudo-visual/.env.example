# ── Criador de Conteúdo Visual — variáveis de ambiente ──
# Copie este arquivo para .env.local e preencha. .env.local é gitignored.

# OBRIGATÓRIO — geração de texto (gpt-5.4-nano) e imagem (gpt-image-1).
# Sem isso, /api/generate e /api/images/generate retornam 503.
OPENAI_API_KEY=

# OPCIONAL — Admin key (sk-admin-…) com scope api.usage.read. Mostra o GASTO do
# mês na header dos editores. Saldo restante NÃO é acessível via API.
OPENAI_ADMIN_KEY=

# OPCIONAL — publicação no Instagram via Composio (REST API).
# Sem isso, o app degrada com elegância (drawer mostra "não configurada").
COMPOSIO_API_KEY=
# COMPOSIO_BASE_URL=https://backend.composio.dev/api/v3  # default; só mude se necessário

# OPCIONAL — hosting de vídeo no Cloudflare R2 (necessário p/ publicar Reels).
# O MP4 é enviado ao R2 e o Instagram busca a URL pública (sem query string).
# As chaves S3 (Access Key ID + Secret) saem de "Manage R2 API Tokens".
R2_ENDPOINT=                # https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=                  # ex.: infosaas-reels (bucket com acesso público ON)
R2_PUBLIC_BASE_URL=         # ex.: https://pub-xxxx.r2.dev

# OPCIONAL — empresa ativa (default: "infosaas"). Define quais paths de DNA usar.
# COMPANY_ID=infosaas

# OPCIONAL/LEGADO — webhook do Activepieces (fluxo antigo de publicação).
# ACTIVEPIECES_WEBHOOK_URL=
# ACTIVEPIECES_WEBHOOK_SECRET=
